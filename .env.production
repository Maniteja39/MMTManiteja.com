# Build-time config for `npm run build`. Vite inlines VITE_* vars into the
# bundle, so this is what the production site talks to. Not a secret — the
# URL is visible in every network request from the browser anyway.
#
# Swap this to https://api.mmtmaniteja.com once the custom domain is wired
# up in Route 53 + Render.
VITE_API_BASE_URL=https://mmtmaniteja-api.onrender.com
